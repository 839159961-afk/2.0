{
  "entities": {
    "GameState": {
      "title": "GameState",
      "description": "The user's saved game state.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's ID" },
        "bag": { "type": "object", "description": "The user's bag contents" },
        "boyState": { "type": "string", "description": "The boy's current state" },
        "travelEndTime": { "type": "number", "description": "When the travel ends" },
        "collection": { "type": "array", "items": { "type": "string" }, "description": "Collected beasts" },
        "gardenHerbs": { "type": "number", "description": "Number of herbs" },
        "logs": { "type": "array", "items": { "type": "string" }, "description": "Game logs" },
        "newSouvenir": { "type": "string", "description": "New souvenir" },
        "acknowledgedMilestones": { "type": "array", "items": { "type": "string" }, "description": "Acknowledged milestones" },
        "activeEncounter": { "type": "object", "description": "Active encounter" },
        "encounterHistory": { "type": "array", "items": { "type": "string" }, "description": "Encounter history" },
        "unlockedDiaries": { "type": "array", "items": { "type": "string" }, "description": "Unlocked diaries" },
        "newDiary": { "type": "string", "description": "New diary" },
        "updatedAt": { "type": "number", "description": "Last update timestamp" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/GameState" },
      "description": "User's game state"
    }
  }
}
